# Copy to backend/.env (or the repo-root .env) and fill in. .env is gitignored — never commit keys.

# --- Required: LLM providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: web-search freshness tool (falls back to DuckDuckGo scraping if unset) ---
TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=

# --- Models (Pydantic AI "<provider>:<model>"). Defaults shown; this is the validated setup. ---
# CG_ANSWERER_MODEL=openai:gpt-5.4-mini       # the ReAct agent
# CG_JUDGE_MODEL=anthropic:claude-sonnet-5    # cross-vendor eval judge
# CG_CRITIC_MODEL=anthropic:claude-sonnet-5   # serving CRAG critic
# CG_CRITIC_THRESHOLD=0.55

# --- Postgres (Cricsheet stats). Local defaults use a Unix socket; set these for a hosted DB. ---
# CG_DB=cricket_guru
# CG_USER=your_user
# CG_HOST=/tmp            # socket dir locally; a hostname for a hosted DB
# CG_PORT=5432
# CG_PASSWORD=            # empty locally (socket auth); set for a hosted DB

# --- Qdrant: unset = on-disk (data/qdrant); set a URL to talk to a Qdrant server (Docker) ---
# CG_QDRANT_URL=http://localhost:6333
